# Android emulator → 10.0.2.2 maps to host machine localhost
# iOS simulator   → localhost works directly
# Physical device → use your machine's LAN IP (e.g. 192.168.1.x)
API_BASE_URL=http://10.0.2.2:3000/api/v1

# Google Maps (Android only — iOS uses Apple Maps by default)
# Create a key at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ─── Firebase ─────────────────────────────────────────────────────────────────
# iOS: Replace ios/frontend/GoogleService-Info.plist with your Firebase project's plist
# Android: Replace android/app/google-services.json with your Firebase project's JSON
# Both files are obtained from Firebase Console > Project Settings > Your Apps
