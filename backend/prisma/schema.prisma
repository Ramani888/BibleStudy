generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  name            String
  email           String          @unique
  password        String
  profileImage    String?
  bio             String?
  church          String?
  creditBalance   Int             @default(3)
  storageUsed     BigInt          @default(0)
  storageLimit    BigInt          @default(209715200)
  plan            Plan            @default(FREE)
  emailVerified   Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  refreshTokens      RefreshToken[]
  deviceTokens       DeviceToken[]
  folders            Folder[]
  sets               Set[]
  cards              Card[]
  notes              Note[]
  files              File[]
  aiChats            AIChat[]
  creditTransactions CreditTransaction[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  Platform
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  userId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets      Set[]
  notes     Note[]
  files     File[]

  @@index([userId])
}

model Set {
  id          String     @id @default(uuid())
  title       String
  description String?
  folderId    String?
  userId      String
  visibility  Visibility @default(PRIVATE)
  layout      CardLayout @default(DEFAULT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  cards       Card[]

  @@index([userId])
  @@index([folderId])
  @@index([visibility])
}

model Card {
  id            String     @id @default(uuid())
  setId         String
  question      String
  answer        String
  imageId       String?
  order         Int        @default(0)
  isBlurred     Boolean    @default(false)
  difficulty    Difficulty @default(MEDIUM)
  lastStudiedAt DateTime?
  nextReviewAt  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  set           Set        @relation(fields: [setId], references: [id], onDelete: Cascade)
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId        String?

  @@index([setId])
  @@index([userId])
}

model Note {
  id             String   @id @default(uuid())
  title          String
  content        String
  userId         String
  folderId       String?
  verseReference String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder         Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
}

model File {
  id        String   @id @default(uuid())
  userId    String
  type      FileType
  url       String
  publicId  String
  size      BigInt
  folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
}

model CreditTransaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Int
  description String
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type, createdAt])
}

model AIChat {
  id          String   @id @default(uuid())
  userId      String
  question    String
  answer      String
  creditsUsed Int      @default(1)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpToken {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum Platform {
  IOS
  ANDROID
}

enum Visibility {
  PRIVATE
  PUBLIC
  FRIENDS
}

enum CardLayout {
  DEFAULT
  MINIMAL
  DETAILED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum FileType {
  IMAGE
  PDF
}

enum TransactionType {
  USAGE
  REWARD
  PURCHASE
  BONUS
}
